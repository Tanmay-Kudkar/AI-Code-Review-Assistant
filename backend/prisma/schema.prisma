// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  SNIPPET
  FILE
}

enum ReviewStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  reviews      Review[]
  sessions     Session[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id           String        @id @default(uuid())
  userId       String
  title        String
  language     String
  framework    String?
  sourceType   SourceType
  rawCode      String        @db.Text
  fileName     String?
  status       ReviewStatus  @default(PENDING)
  errorMessage String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  staticResult StaticResult?
  aiResult     AiResult?
  complexity   Complexity?
}

model StaticResult {
  id        String   @id @default(uuid())
  reviewId  String   @unique
  issues    Json     // Array of { line, column, severity, rule, message }
  summary   Json     // { errors, warnings, info, total }
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model AiResult {
  id                String   @id @default(uuid())
  reviewId          String   @unique
  bugs              Json     @default("[]")
  smells            Json     @default("[]")
  suggestions       Json     @default("[]")
  security          Json     @default("[]")
  performance       Json     @default("[]")
  complexities      Json     @default("[]") // Big-O per-function analysis from AI
  documentation     String   @db.Text @default("")
  refactoring       String   @db.Text @default("")
  rawResponse       String   @db.Text @default("")
  sectionsStatus    Json     @default("{}") // { aiReview, documentation, bigO, refactoring } each: pending|processing|done|failed
  createdAt         DateTime @default(now())
  review            Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Complexity {
  id             String   @id @default(uuid())
  reviewId       String   @unique
  linesOfCode    Int      @default(0)
  numFunctions   Int      @default(0)
  numClasses     Int      @default(0)
  cyclomaticAvg  Float    @default(0)
  complexity     Json     @default("[]") // Per-function breakdown
  difficulty     String   @default("Low") // Low | Medium | High
  createdAt      DateTime @default(now())
  review         Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}
